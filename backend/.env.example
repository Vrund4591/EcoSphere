NODE_ENV=development
PORT=5001
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Local dev-postgres (Docker). Create the DB once:
#   docker start dev-postgres
#   docker exec dev-postgres psql -U postgres -c "CREATE DATABASE ecosphere_db;"
DATABASE_URL="postgresql://postgres:mysecretpassword@localhost:5432/ecosphere_db?schema=public"

JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Optional email (Tier 3 notifications) — leave blank to disable
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=EcoSphere <no-reply@ecosphere.local>
